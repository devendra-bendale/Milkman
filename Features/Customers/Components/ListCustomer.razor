
@inject CustomerService CustomerService

<div class="row">
    @* <button class="btn btn-primary rounded-circle shadow add-button" @onclick="AddNewOrder">
        +
    </button> *@

    <div class="col-12">
        <div class="my-3">
            <input class="form-control"
                   placeholder="Search by name or contact number..."
                   value="@searchText"
                   @oninput="OnSearchInput" />
        </div>
    </div>
</div>

@if (!customers.Any())
{
    <p>No customers found.</p>
}
else
{
    @if (!FilteredCustomers.Any())
    {
        <p>No customers match your search.</p>
    }
    else
    {
        <div class="row g-3">
            @foreach (var c in FilteredCustomers)
            {
                <div class="col-12 col-md-6 col-lg-4">
                    <div class="card">
                        <EditViewCustomer Customer="c" OnSave="HandleSave" OnDelete="HandleDelete"></EditViewCustomer>
                    </div>
                </div>
            }
        </div>
    }
}

@code {
    private List<CustomerViewModel> customers = new();
    private string searchText = string.Empty;
    [Parameter]
    public EventCallback<bool> OnLoadingChanged { get; set; }

    protected override async Task OnInitializedAsync()
    {
        await OnLoadingChanged.InvokeAsync(true);
        await LoadAsync();
        await OnLoadingChanged.InvokeAsync(false);
    }

    private IEnumerable<CustomerViewModel> FilteredCustomers
    {
        get
        {
            var q = (searchText ?? string.Empty).Trim();

            if (string.IsNullOrWhiteSpace(q))
                return customers;

            return customers.Where(c =>
                (!string.IsNullOrEmpty(c.Name) && c.Name.Contains(q, StringComparison.OrdinalIgnoreCase))
                || (!string.IsNullOrEmpty(c.ContactNumber) && c.ContactNumber.Contains(q, StringComparison.OrdinalIgnoreCase)));
        }
    }

    public async Task LoadAsync()
    {
        customers = await CustomerService.GetAllAsync();
        StateHasChanged();        
    }

    private void OnSearchInput(ChangeEventArgs e)
    {
        searchText = e?.Value?.ToString() ?? string.Empty;
        StateHasChanged();
    }

    private async Task HandleSave(CustomerViewModel model)
    {
        await OnLoadingChanged.InvokeAsync(true);
        await CustomerService.UpdateAsync(model);
        await LoadAsync();
        await OnLoadingChanged.InvokeAsync(false);
    }

    private async Task HandleDelete(int id)
    {
        bool result = await Application.Current.MainPage.DisplayAlert(
                        "Delete",
                        "Are you sure you want to delete this Customer?",
                        "Yes",
                        "No");
        if (result)
        {
            await OnLoadingChanged.InvokeAsync(true);
            await CustomerService.DeleteAsync(id);
            await LoadAsync();
            await OnLoadingChanged.InvokeAsync(false);
        }
    }
}
