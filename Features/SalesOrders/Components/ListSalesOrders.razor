@page "/listSalesOrders"
@using Milkman2.Services.SalesOrders
@inject SalesOrderService soService
@inject NavigationManager navManager

<SectionContent SectionName="pageTitle">
    <div class="d-flex justify-content-between align-items-center">
        Customer Order
        <button class="btn btn-primary" @onclick="AddNewOrder">
            Add
        </button>
    </div>
</SectionContent>

<div class="row">
    @* <button class="btn btn-primary rounded-circle shadow add-button" @onclick="AddNewOrder">
        +
    </button> *@
    <div class="col-12">
        <div class="my-3">
            <input class="form-control"
                   placeholder="Search by customer name..."
                   value="@searchText"
                   @oninput="OnSearchInput" />
        </div>
    </div>
</div>
@if (!FilteredSalesOrder.Any())
{
    <p>No customer order found.</p>
}
else
{
    foreach (var salesOrder in FilteredSalesOrder)
    {
        <div class="card m-1" @onclick="() => EditOrder(salesOrder.Id)" style="cursor:pointer">
            <div class="card-body py-3 px-4">

                <div class="row align-items-center">
                    <!-- Left Section -->
                    <div class="col-6">
                        <b class="fw-bold fs-5">@salesOrder.CustomerName</b>
                        <br />
                        @salesOrder.StartDate.ToShortDateString()
                        <br />
                        @salesOrder.MilkTypeName
                    </div>
                    <!-- Right Section -->
                    <div class="col-6">
                        @salesOrder.Frequency
                        <br />
                        @salesOrder.Quantity ltrs
                        <br />
                        @salesOrder.Rate Rs./ltr
                    </div>
                </div>                
            </div>
        </div>
    }
}

<CustomOverlay @bind-Visible="isLoading" DarkBackground="true" AutoClose="false">
    <div class="spinner"></div>
    <p style="color: white; margin-top: 10px;">Processing, please wait...</p>
</CustomOverlay>

@code {
    private bool isLoading = false;
    private List<SalesOrderViewModel> salesOrders = new();
    private string searchText = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        isLoading = true;
        await LoadAsync();
        isLoading = false;
    }

    public async Task LoadAsync()
    {
        salesOrders = await soService.GetAllAsync();
        StateHasChanged();
    }

    private IEnumerable<SalesOrderViewModel> FilteredSalesOrder
    {
        get
        {
            var q = (searchText ?? string.Empty).Trim();

            if (string.IsNullOrWhiteSpace(q))
                return salesOrders;

            return salesOrders.Where(c =>
                (!string.IsNullOrEmpty(c.CustomerName) && c.CustomerName.Contains(q, StringComparison.OrdinalIgnoreCase)));
        }
    }

    private void OnSearchInput(ChangeEventArgs e)
    {
        searchText = e?.Value?.ToString() ?? string.Empty;
        StateHasChanged();
    }

    private void AddNewOrder()
    {
        navManager.NavigateTo("/addSalesOrder");
    }

    private void EditOrder(int id)
    {
        navManager.NavigateTo($"/addSalesOrder/{id}");
    }
}
